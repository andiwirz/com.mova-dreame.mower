{
  "name": {
    "en": "Robotic Lawn Mower",
    "de": "Mähroboter"
  },
  "class": "lawnmower",
  "capabilities": [
    "mower_status",
    "cmd_all_area",
    "cmd_stop",
    "cmd_pause",
    "cmd_edge_mowing",
    "cmd_dock",
    "charging_status",
    "measure_battery",
    "alarm_generic",
    "mow_efficiency",
    "collision_avoidance",
    "firmware_update",
    "measure_duration",
    "child_lock",
    "mower_volume",
    "consumable_blade",
    "consumable_brush",
    "consumable_robot"
  ],
  "capabilitiesOptions": {
    "alarm_generic": {
      "title": { "en": "Error", "de": "Fehler" }
    },
    "measure_battery": {
      "title": { "en": "Battery", "de": "Akku" }
    }
  },
  "energy": {
    "batteries": ["INTERNAL"]
  },
  "images": {
    "small": "/drivers/mower/assets/images/small.png",
    "large": "/drivers/mower/assets/images/large.png"
  },
  "pair": [
    { "id": "pair" }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Device Info", "de": "Geräteinformationen" },
      "children": [
        {
          "id": "device_model",
          "type": "label",
          "label": { "en": "Model", "de": "Modell" },
          "value": ""
        },
        {
          "id": "firmware_version",
          "type": "label",
          "label": { "en": "Firmware Version", "de": "Firmware-Version" },
          "value": ""
        },
        {
          "id": "serial_number",
          "type": "label",
          "label": { "en": "Serial Number", "de": "Seriennummer" },
          "value": ""
        },
        {
          "id": "mac_address",
          "type": "label",
          "label": { "en": "MAC Address", "de": "MAC-Adresse" },
          "value": ""
        },
        {
          "id": "username",
          "type": "label",
          "label": { "en": "Email", "de": "E-Mail" },
          "value": ""
        },
        {
          "id": "brand",
          "type": "label",
          "label": { "en": "Brand", "de": "Marke" },
          "value": ""
        },
        {
          "id": "region",
          "type": "label",
          "label": { "en": "Region", "de": "Region" },
          "value": ""
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Zones", "de": "Zonen" },
      "children": [
        {
          "id": "num_zones",
          "type": "label",
          "label": { "en": "Number of zones", "de": "Anzahl Zonen" },
          "value": "",
          "hint": {
            "en": "Auto-detected from map data. One Zone button per zone appears on the device card.",
            "de": "Wird automatisch aus den Kartendaten erkannt. Pro Zone erscheint ein Zonen-Button auf der Gerätekarte."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Child Lock", "de": "Kindersicherung" },
      "children": [
        {
          "id": "cls_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false,
          "hint": {
            "en": "Locks physical buttons on the mower so it cannot be started manually.",
            "de": "Sperrt die physischen Tasten am Mähroboter, damit er nicht manuell gestartet werden kann."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Frost Protection", "de": "Frostschutz" },
      "children": [
        {
          "id": "fdp_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false,
          "hint": {
            "en": "The mower will not mow when frost is detected.",
            "de": "Der Mähroboter mäht nicht, wenn Frost erkannt wird."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Rain Protection", "de": "Regenschutz" },
      "children": [
        {
          "id": "wrp_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false
        },
        {
          "id": "wrp_sensitivity",
          "type": "number",
          "label": { "en": "Sensitivity", "de": "Empfindlichkeit" },
          "value": 1,
          "min": 1,
          "max": 3,
          "step": 1,
          "hint": {
            "en": "Rain detection sensitivity (1 = low, 3 = high).",
            "de": "Regenerkennungs-Empfindlichkeit (1 = niedrig, 3 = hoch)."
          }
        },
        {
          "id": "wrp_wait_time",
          "type": "number",
          "label": { "en": "Wait time (h)", "de": "Wartezeit (Std.)" },
          "value": 7,
          "min": 1,
          "max": 24,
          "step": 1,
          "hint": {
            "en": "Hours to wait after rain before resuming mowing.",
            "de": "Stunden Wartezeit nach dem Regen, bevor das Mähen fortgesetzt wird."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Lighting", "de": "Beleuchtung" },
      "children": [
        {
          "id": "lit_enabled",
          "type": "checkbox",
          "label": { "en": "Custom LED activation time window", "de": "Benutzerdefinierter LED-Aktivierungszeitraum" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower only turns on the light during the specified time window.",
            "de": "Wenn aktiviert, schaltet der Roboter das Licht nur während des angegebenen Zeitraums ein."
          }
        },
        {
          "id": "lit_time_start",
          "type": "number",
          "label": { "en": "Start (h)", "de": "Start (Uhr)" },
          "value": 8,
          "min": 0,
          "max": 23,
          "step": 1,
          "hint": {
            "en": "Start of the LED activation window (e.g. 8 = 08:00).",
            "de": "Beginn des LED-Aktivierungszeitraums (z. B. 8 = 08:00 Uhr)."
          }
        },
        {
          "id": "lit_time_end",
          "type": "number",
          "label": { "en": "End (h)", "de": "Ende (Uhr)" },
          "value": 20,
          "min": 1,
          "max": 24,
          "step": 1,
          "hint": {
            "en": "End of the LED activation window (e.g. 20 = 20:00).",
            "de": "Ende des LED-Aktivierungszeitraums (z. B. 20 = 20:00 Uhr)."
          }
        },
        {
          "id": "lit_standby",
          "type": "checkbox",
          "label": { "en": "Light in standby", "de": "Licht im Standby" },
          "value": false,
          "hint": {
            "en": "Turn on the LED when the mower is in standby.",
            "de": "LED leuchtet, wenn der Mähroboter im Standby ist."
          }
        },
        {
          "id": "lit_working",
          "type": "checkbox",
          "label": { "en": "Light while mowing", "de": "Licht während des Mähens" },
          "value": false,
          "hint": {
            "en": "Turn on the LED while the mower is working.",
            "de": "LED leuchtet, während der Mähroboter mäht."
          }
        },
        {
          "id": "lit_charging",
          "type": "checkbox",
          "label": { "en": "Light while charging", "de": "Licht beim Laden" },
          "value": false,
          "hint": {
            "en": "Turn on the LED while the mower is charging.",
            "de": "LED leuchtet, während der Mähroboter geladen wird."
          }
        },
        {
          "id": "lit_error",
          "type": "checkbox",
          "label": { "en": "Light on error", "de": "Licht bei Fehler" },
          "value": false,
          "hint": {
            "en": "Turn on the LED when the mower reports an error.",
            "de": "LED leuchtet, wenn der Mähroboter einen Fehler meldet."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Battery", "de": "Akku" },
      "children": [
        {
          "id": "bat_return_pct",
          "type": "number",
          "label": { "en": "Return charging threshold (%)", "de": "Ladestand für automatisches Aufladen (%)" },
          "value": 15,
          "min": 5,
          "max": 90,
          "step": 5,
          "hint": {
            "en": "The mower returns to the dock automatically when the battery drops to this level.",
            "de": "Der Mähroboter kehrt automatisch zur Station zurück, wenn der Akkustand auf diesen Wert sinkt."
          }
        },
        {
          "id": "bat_resume_pct",
          "type": "number",
          "label": { "en": "Resume task threshold (%)", "de": "Ladestand für Wiederaufnahme der Aufgaben (%)" },
          "value": 100,
          "min": 10,
          "max": 100,
          "step": 5,
          "hint": {
            "en": "After charging, the mower resumes its task automatically once the battery reaches this level.",
            "de": "Nach dem Aufladen setzt der Mähroboter die Aufgabe automatisch fort, sobald der Akku diesen Ladestand erreicht hat."
          }
        },
        {
          "id": "bat_auto_resume",
          "type": "checkbox",
          "label": { "en": "Resume mowing after charging", "de": "Mähen nach dem Laden fortsetzen" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower automatically resumes its unfinished task after charging is complete.",
            "de": "Wenn aktiviert, setzt der Roboter die unerledigte Aufgabe nach Abschluss der Ladezeit automatisch fort."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Low Speed at Night", "de": "Niedrige Geschwindigkeit in der Nacht" },
      "children": [
        {
          "id": "low_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower automatically slows down during the set time window to protect animals active at night.",
            "de": "Wenn aktiviert, verlangsamt sich der Roboter automatisch während des festgelegten Zeitraums, um Tiere zu schützen."
          }
        },
        {
          "id": "low_start",
          "type": "number",
          "label": { "en": "Start (h)", "de": "Start (Uhr)" },
          "value": 20,
          "min": 0,
          "max": 23,
          "step": 1,
          "hint": {
            "en": "Start of the low-speed window (e.g. 20 = 20:00).",
            "de": "Beginn des Langsamfahr-Zeitraums (z. B. 20 = 20:00 Uhr)."
          }
        },
        {
          "id": "low_end",
          "type": "number",
          "label": { "en": "End (h)", "de": "Ende (Uhr)" },
          "value": 8,
          "min": 0,
          "max": 23,
          "step": 1,
          "hint": {
            "en": "End of the low-speed window (e.g. 8 = 08:00 next day).",
            "de": "Ende des Langsamfahr-Zeitraums (z. B. 8 = 08:00 Uhr nächsten Tag)."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Do Not Disturb", "de": "Bitte nicht stören" },
      "children": [
        {
          "id": "dnd_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower will not start automatically during the set time window. If it is already mowing it will stop and return to the dock.",
            "de": "Wenn aktiviert, beginnt der Mähroboter innerhalb des eingestellten Zeitraums nicht automatisch. Wenn er bereits mäht, unterbricht er die Arbeit und kehrt zur Station zurück."
          }
        },
        {
          "id": "dnd_start",
          "type": "number",
          "label": { "en": "Start (h)", "de": "Start (Uhr)" },
          "value": 22,
          "min": 0,
          "max": 23,
          "step": 1,
          "hint": {
            "en": "Start of the Do Not Disturb window (e.g. 22 = 22:00).",
            "de": "Beginn des Bitte-nicht-stören-Zeitraums (z. B. 22 = 22:00 Uhr)."
          }
        },
        {
          "id": "dnd_end",
          "type": "number",
          "label": { "en": "End (h)", "de": "Ende (Uhr)" },
          "value": 8,
          "min": 0,
          "max": 23,
          "step": 1,
          "hint": {
            "en": "End of the Do Not Disturb window (e.g. 8 = 08:00 next day).",
            "de": "Ende des Bitte-nicht-stören-Zeitraums (z. B. 8 = 08:00 Uhr nächsten Tag)."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Voice Announcements", "de": "Sprachansagemodi" },
      "children": [
        {
          "id": "voice_notification",
          "type": "checkbox",
          "label": { "en": "Regular notification", "de": "Regelmäßige Benachrichtigungsansage" },
          "value": false,
          "hint": {
            "en": "The mower announces regular status notifications.",
            "de": "Der Mähroboter gibt regelmäßige Benachrichtigungsansagen aus."
          }
        },
        {
          "id": "voice_work_status",
          "type": "checkbox",
          "label": { "en": "Work status", "de": "Arbeitsstatusansage" },
          "value": false,
          "hint": {
            "en": "The mower announces work status changes (e.g. mowing started, returning to dock).",
            "de": "Der Mähroboter gibt Arbeitsstatusänderungen aus (z. B. Mähen gestartet, Rückkehr zur Station)."
          }
        },
        {
          "id": "voice_special_status",
          "type": "checkbox",
          "label": { "en": "Special status", "de": "Spezialstatusansage" },
          "value": false,
          "hint": {
            "en": "The mower announces special status events.",
            "de": "Der Mähroboter gibt Ansagen zu besonderen Statusereignissen aus."
          }
        },
        {
          "id": "voice_error_status",
          "type": "checkbox",
          "label": { "en": "Error status", "de": "Fehlerstatusansage" },
          "value": false,
          "hint": {
            "en": "The mower announces error conditions.",
            "de": "Der Mähroboter gibt Fehlermeldungen als Sprachansage aus."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Anti-Theft Alarm", "de": "Anti-Diebstahl-Alarm" },
      "children": [
        {
          "id": "ata_lift",
          "type": "checkbox",
          "label": { "en": "Lift alarm", "de": "Hebealarm" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower locks itself and triggers an alarm immediately when lifted.",
            "de": "Wenn aktiviert, wird der Roboter gesperrt und der Alarm wird sofort ausgelöst, wenn er angehoben wird."
          }
        },
        {
          "id": "ata_map_alarm",
          "type": "checkbox",
          "label": { "en": "Alarm when leaving the map", "de": "Alarm bei Verlassen der Karte" },
          "value": false,
          "hint": {
            "en": "Triggers an alarm when the mower leaves the mapped area. Requires the Link module.",
            "de": "Löst einen Alarm aus, wenn der Mähroboter die kartierte Fläche verlässt. Erfordert das Link-Modul."
          }
        },
        {
          "id": "ata_realtime",
          "type": "checkbox",
          "label": { "en": "Real-time location", "de": "Standort in Echtzeit" },
          "value": false,
          "hint": {
            "en": "Enables real-time GPS location tracking. Requires the Link module.",
            "de": "Aktiviert die GPS-Echtzeit-Standortverfolgung. Erfordert das Link-Modul."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "AI Obstacle Detection", "de": "KI-Hinderniserkennung" },
      "children": [
        {
          "id": "aop_enabled",
          "type": "checkbox",
          "label": { "en": "Capture photos of AI-detected obstacles", "de": "Fotos von KI-erkannten Hindernissen aufnehmen" },
          "value": false,
          "hint": {
            "en": "When enabled, the mower photographs obstacles detected by AI. You can then tap the obstacle icons on the map in the manufacturer app to view the actual photos.",
            "de": "Wenn aktiviert, fotografiert der Mähroboter erkannte Hindernisse. Die Fotos können in der Hersteller-App durch Tippen auf die Hindernissymbole auf der Karte angezeigt werden."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Connection", "de": "Verbindung" },
      "children": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Poll Interval (seconds)", "de": "Abfrageintervall (Sekunden)" },
          "value": 30,
          "min": 10,
          "max": 300,
          "step": 5,
          "hint": {
            "en": "How often the mower status is polled.",
            "de": "Wie oft der Status abgefragt wird."
          }
        }
      ]
    }
  ]
}
