{
  "name": {
    "en": "Robotic Lawn Mower",
    "de": "Mähroboter"
  },
  "class": "lawnmower",
  "capabilities": [
    "mower_status",
    "mower_mode",
    "mowing_speed",
    "mower_progress",
    "charging_status",
    "measure_battery",
    "alarm_generic",
    "alarm_obstacle",
    "alarm_tilt",
    "alarm_lift",
    "mower_task_status",
    "consumable_blade",
    "consumable_brush",
    "consumable_robot",
    "child_lock",
    "dnd_enabled",
    "rain_protection",
    "frost_protection",
    "grass_protection",
    "night_mode",
    "mower_pattern",
    "mow_efficiency",
    "anti_theft",
    "collision_avoidance",
    "auto_charging",
    "mower_error_code",
    "firmware_update",
    "measure_area",
    "measure_duration",
    "meter_area_total",
    "meter_time_total",
    "meter_count_total"
  ],
  "capabilitiesOptions": {
    "alarm_generic": {
      "title": { "en": "Error", "de": "Fehler" }
    },
    "measure_battery": {
      "title": { "en": "Battery", "de": "Akku" }
    },
    "mower_error_code": {
      "title": { "en": "Error Code", "de": "Fehlercode" },
      "preventInsights": false
    },
    "meter_area_total": {
      "preventInsights": false
    },
    "meter_time_total": {
      "preventInsights": false
    }
  },
  "energy": {
    "batteries": ["INTERNAL"]
  },
  "images": {
    "small": "/drivers/mower/assets/images/small.png",
    "large": "/drivers/mower/assets/images/large.png"
  },
  "pair": [
    { "id": "pair" }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Device Info", "de": "Geräteinformationen" },
      "children": [
        {
          "id": "device_model",
          "type": "text",
          "label": { "en": "Model", "de": "Modell" },
          "value": ""
        },
        {
          "id": "username",
          "type": "text",
          "label": { "en": "Email", "de": "E-Mail" },
          "value": ""
        },
        {
          "id": "brand",
          "type": "text",
          "label": { "en": "Brand", "de": "Marke" },
          "value": "dreame"
        },
        {
          "id": "region",
          "type": "text",
          "label": { "en": "Region", "de": "Region" },
          "value": "eu"
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Mowing", "de": "Mähen" },
      "children": [
        {
          "id": "border_first",
          "type": "checkbox",
          "label": { "en": "Mow border first", "de": "Rand zuerst mähen" },
          "value": false,
          "hint": {
            "en": "Mow the perimeter edge before mowing the main area.",
            "de": "Randstreifen vor dem Hauptbereich mähen."
          }
        },
        {
          "id": "edge_mowing",
          "type": "checkbox",
          "label": { "en": "Edge mowing", "de": "Kantenmähen" },
          "value": false,
          "hint": {
            "en": "Enable edge mowing preference (PRE). The mower stays closer to boundaries.",
            "de": "Kantenmäh-Präferenz aktivieren (PRE). Der Mähroboter bleibt näher an den Grenzen."
          }
        },
        {
          "id": "obstacle_avoidance",
          "type": "number",
          "label": { "en": "Obstacle avoidance sensitivity", "de": "Hindernisempfindlichkeit" },
          "value": 2,
          "min": 0,
          "max": 3,
          "step": 1,
          "hint": {
            "en": "0 = Off, 1 = Low, 2 = Medium, 3 = High",
            "de": "0 = Aus, 1 = Niedrig, 2 = Mittel, 3 = Hoch"
          }
        },
        {
          "id": "cutting_height_min",
          "type": "number",
          "label": { "en": "Min. cutting height (mm)", "de": "Minimale Schnitthöhe (mm)" },
          "value": 30,
          "min": 10,
          "max": 200,
          "step": 5,
          "hint": {
            "en": "Lowest blade position supported by your mower model. Check the manual.",
            "de": "Niedrigste Messerposition deines Modells. Im Handbuch nachsehen."
          }
        },
        {
          "id": "cutting_height_max",
          "type": "number",
          "label": { "en": "Max. cutting height (mm)", "de": "Maximale Schnitthöhe (mm)" },
          "value": 100,
          "min": 10,
          "max": 200,
          "step": 5,
          "hint": {
            "en": "Highest blade position supported by your mower model. Check the manual.",
            "de": "Höchste Messerposition deines Modells. Im Handbuch nachsehen."
          }
        },
        {
          "id": "cutting_height",
          "type": "number",
          "label": { "en": "Cutting height (mm)", "de": "Schnitthöhe (mm)" },
          "value": 60,
          "min": 10,
          "max": 200,
          "step": 5,
          "hint": {
            "en": "Current blade height. Must be within the min/max range above. Changes are sent to the mower immediately.",
            "de": "Aktuelle Messerhöhe. Muss im Min./Max.-Bereich liegen. Änderungen werden sofort an den Mähroboter gesendet."
          }
        },
        {
          "id": "auto_resume",
          "type": "checkbox",
          "label": { "en": "Continue after recharging", "de": "Nach dem Laden weiterfahren" },
          "value": true,
          "hint": {
            "en": "The mower automatically continues the mowing task after returning to the dock to recharge.",
            "de": "Der Mähroboter setzt die Mähaufgabe nach dem Laden an der Station automatisch fort."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Battery", "de": "Akku" },
      "children": [
        {
          "id": "return_battery_threshold",
          "type": "number",
          "label": { "en": "Return threshold (%)", "de": "Rückkehrschwelle (%)" },
          "value": 20,
          "min": 5,
          "max": 50,
          "step": 5,
          "hint": {
            "en": "Battery level at which the mower returns to the dock to recharge.",
            "de": "Akkustand, bei dem der Mähroboter zur Station zurückkehrt."
          }
        },
        {
          "id": "resume_battery_threshold",
          "type": "number",
          "label": { "en": "Resume threshold (%)", "de": "Weitermähschwelle (%)" },
          "value": 80,
          "min": 50,
          "max": 100,
          "step": 5,
          "hint": {
            "en": "Battery level at which the mower resumes mowing after recharging.",
            "de": "Akkustand, ab dem der Mähroboter nach dem Laden weitermäht."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Sound", "de": "Ton" },
      "children": [
        {
          "id": "volume",
          "type": "number",
          "label": { "en": "Volume (%)", "de": "Lautstärke (%)" },
          "value": 50,
          "min": 0,
          "max": 100,
          "step": 10,
          "hint": {
            "en": "Mower speaker volume for alerts and notifications.",
            "de": "Lautstärke des Mähroboter-Lautsprechers für Meldungen."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Do Not Disturb", "de": "Nicht stören" },
      "children": [
        {
          "id": "dnd_start",
          "type": "text",
          "label": { "en": "Quiet hours start (HH:MM)", "de": "Ruhezeit Beginn (HH:MM)" },
          "value": "22:00",
          "hint": {
            "en": "Start of the quiet hours window. The mower will not start automatically during this period.",
            "de": "Beginn der Ruhezeit. In dieser Zeit startet der Mähroboter nicht automatisch."
          }
        },
        {
          "id": "dnd_end",
          "type": "text",
          "label": { "en": "Quiet hours end (HH:MM)", "de": "Ruhezeit Ende (HH:MM)" },
          "value": "07:00",
          "hint": {
            "en": "End of the quiet hours window.",
            "de": "Ende der Ruhezeit."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Connection", "de": "Verbindung" },
      "children": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Poll Interval (seconds)", "de": "Abfrageintervall (Sekunden)" },
          "value": 30,
          "min": 10,
          "max": 300,
          "step": 5,
          "hint": {
            "en": "How often the mower status is polled.",
            "de": "Wie oft der Status abgefragt wird."
          }
        }
      ]
    }
  ]
}
