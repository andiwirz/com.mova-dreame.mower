{
  "name": {
    "en": "Robotic Lawn Mower",
    "de": "Mähroboter"
  },
  "class": "lawnmower",
  "capabilities": [
    "mower_status",
    "cmd_all_area",
    "cmd_stop",
    "cmd_pause",
    "cmd_edge_mowing",
    "cmd_dock",
    "charging_status",
    "measure_battery",
    "alarm_generic",
    "mow_efficiency",
    "collision_avoidance",
    "firmware_update",
    "measure_duration",
    "mower_task_status",
    "child_lock"
  ],
  "capabilitiesOptions": {
    "alarm_generic": {
      "title": { "en": "Error", "de": "Fehler" }
    },
    "measure_battery": {
      "title": { "en": "Battery", "de": "Akku" }
    }
  },
  "energy": {
    "batteries": ["INTERNAL"]
  },
  "images": {
    "small": "/drivers/mower/assets/images/small.png",
    "large": "/drivers/mower/assets/images/large.png"
  },
  "pair": [
    { "id": "pair" }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Device Info", "de": "Geräteinformationen" },
      "children": [
        {
          "id": "device_model",
          "type": "label",
          "label": { "en": "Model", "de": "Modell" },
          "value": ""
        },
        {
          "id": "firmware_version",
          "type": "label",
          "label": { "en": "Firmware Version", "de": "Firmware-Version" },
          "value": ""
        },
        {
          "id": "serial_number",
          "type": "label",
          "label": { "en": "Serial Number", "de": "Seriennummer" },
          "value": ""
        },
        {
          "id": "mac_address",
          "type": "label",
          "label": { "en": "MAC Address", "de": "MAC-Adresse" },
          "value": ""
        },
        {
          "id": "username",
          "type": "label",
          "label": { "en": "Email", "de": "E-Mail" },
          "value": ""
        },
        {
          "id": "brand",
          "type": "label",
          "label": { "en": "Brand", "de": "Marke" },
          "value": ""
        },
        {
          "id": "region",
          "type": "label",
          "label": { "en": "Region", "de": "Region" },
          "value": ""
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Zones", "de": "Zonen" },
      "children": [
        {
          "id": "num_zones",
          "type": "label",
          "label": { "en": "Number of zones", "de": "Anzahl Zonen" },
          "value": "",
          "hint": {
            "en": "Auto-detected from map data. One Zone button per zone appears on the device card.",
            "de": "Wird automatisch aus den Kartendaten erkannt. Pro Zone erscheint ein Zonen-Button auf der Gerätekarte."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Frost Protection", "de": "Frostschutz" },
      "children": [
        {
          "id": "fdp_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false,
          "hint": {
            "en": "The mower will not mow when frost is detected.",
            "de": "Der Mähroboter mäht nicht, wenn Frost erkannt wird."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Rain Protection", "de": "Regenschutz" },
      "children": [
        {
          "id": "wrp_enabled",
          "type": "checkbox",
          "label": { "en": "Enabled", "de": "Aktiviert" },
          "value": false
        },
        {
          "id": "wrp_sensitivity",
          "type": "number",
          "label": { "en": "Sensitivity", "de": "Empfindlichkeit" },
          "value": 1,
          "min": 1,
          "max": 3,
          "step": 1,
          "hint": {
            "en": "Rain detection sensitivity (1 = low, 3 = high).",
            "de": "Regenerkennungs-Empfindlichkeit (1 = niedrig, 3 = hoch)."
          }
        },
        {
          "id": "wrp_wait_time",
          "type": "number",
          "label": { "en": "Wait time (h)", "de": "Wartezeit (Std.)" },
          "value": 7,
          "min": 1,
          "max": 24,
          "step": 1,
          "hint": {
            "en": "Hours to wait after rain before resuming mowing.",
            "de": "Stunden Wartezeit nach dem Regen, bevor das Mähen fortgesetzt wird."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Connection", "de": "Verbindung" },
      "children": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Poll Interval (seconds)", "de": "Abfrageintervall (Sekunden)" },
          "value": 30,
          "min": 10,
          "max": 300,
          "step": 5,
          "hint": {
            "en": "How often the mower status is polled.",
            "de": "Wie oft der Status abgefragt wird."
          }
        }
      ]
    }
  ]
}
