{
  "title": { "en": "Start zone mowing", "de": "Zonenmähen starten" },
  "titleFormatted": { "en": "Start mowing zones [[zones]] ([[passes]]×)", "de": "Zonen [[zones]] mähen ([[passes]]×)" },
  "hint": { "en": "Enter the zone IDs as configured in the MOVA or Dreame app, separated by commas (e.g. 1,2,3). Passes = number of times each zone is mowed.", "de": "Zonen-IDs wie in der MOVA- oder Dreame-App vergeben, kommagetrennt (z.B. 1,2,3). Durchgänge = Anzahl der Mähdurchläufe pro Zone." },
  "args": [
    { "name": "device", "type": "device", "filter": "driver_id=mower" },
    {
      "name": "zones",
      "type": "text",
      "title": { "en": "Zone IDs (comma-separated)", "de": "Zonen-IDs (kommagetrennt)" },
      "placeholder": { "en": "1,2,3", "de": "1,2,3" }
    },
    {
      "name": "passes",
      "type": "number",
      "title": { "en": "Passes", "de": "Durchgänge" },
      "placeholder": { "en": "1", "de": "1" },
      "min": 1,
      "max": 4,
      "step": 1
    }
  ]
}
