{
  "title": { "en": "Consumable needs replacement", "de": "Verbrauchsmaterial muss ersetzt werden" },
  "titleFormatted": { "en": "Consumable drops below [[threshold]]%", "de": "Verbrauchsmaterial fällt unter [[threshold]]%" },
  "hint": {
    "en": "Triggers when blade, brush, or robot life drops below the set percentage.",
    "de": "Wird ausgelöst wenn die Restlebensdauer von Messer, Bürste oder Roboter unter den eingestellten Wert fällt."
  },
  "args": [
    { "name": "device", "type": "device", "filter": "driver_id=mower" },
    {
      "name": "threshold", "type": "number",
      "title": { "en": "Below (%)", "de": "Unter (%)" },
      "min": 1, "max": 100, "step": 1,
      "placeholder": { "en": "20", "de": "20" }
    }
  ],
  "tokens": [
    { "name": "consumable_type", "type": "string", "title": { "en": "Consumable", "de": "Verbrauchsmaterial" } },
    { "name": "remaining_pct",   "type": "number", "title": { "en": "Remaining (%)", "de": "Verbleibend (%)" } }
  ]
}
