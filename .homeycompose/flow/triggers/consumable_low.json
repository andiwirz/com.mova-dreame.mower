{
  "title": { "en": "Consumable health is low", "de": "Verbrauchsmaterial niedrig" },
  "titleFormatted": { "en": "[[consumable]] health drops below [[threshold]]%", "de": "[[consumable]] unter [[threshold]]%" },
  "hint": { "en": "Triggers once when the remaining health of the selected part falls below the threshold. Use this to get a timely replacement reminder.", "de": "Wird einmalig ausgelöst wenn die verbleibende Lebensdauer des Teils unter den Schwellenwert fällt. Ideal als Erinnerung zum rechtzeitigen Austausch." },
  "args": [
    { "name": "device", "type": "device", "filter": "driver_id=mower" },
    {
      "name": "consumable", "type": "dropdown",
      "title": { "en": "Consumable", "de": "Verbrauchsmaterial" },
      "values": [
        { "id": "blade", "label": { "en": "Blade",  "de": "Klinge"  } },
        { "id": "brush", "label": { "en": "Brush",  "de": "Bürste"  } },
        { "id": "robot", "label": { "en": "Robot",  "de": "Roboter" } }
      ]
    },
    {
      "name": "threshold", "type": "number",
      "title": { "en": "Below (%)", "de": "Unter (%)" },
      "min": 1, "max": 100, "step": 5,
      "placeholder": { "en": "20", "de": "20" }
    }
  ]
}
